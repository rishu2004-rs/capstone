<div class="flex justify-center items-center py-6">
    <div class="w-full max-w-lg animate-scale-in">
    <div class="bg-white dark:bg-slate-900 p-10 rounded-[2.5rem] border border-slate-100 dark:border-slate-800 shadow-2xl shadow-slate-200/50 dark:shadow-none">
        <div class="text-center mb-8">
        <h2 class="text-3xl font-extrabold mb-2 dark:text-white">Create Account</h2>
        <p class="text-slate-500 dark:text-slate-400 font-medium">Join the E-Court network</p>
        </div>

        <div id="error-container" class="hidden mb-6 p-4 bg-red-50 dark:bg-red-900/20 border border-red-100 dark:border-red-900/30 rounded-2xl flex items-center gap-3 text-red-600 dark:text-red-400 text-sm font-medium animate-shake">
            <i data-lucide="alert-circle" width="18" height="18"></i>
            <span id="error-text"></span>
        </div>

        <form id="registerForm" onsubmit="handleRegisterSubmit(event)" class="space-y-5">
        <div class="space-y-2">
            <label class="text-sm font-bold text-slate-700 dark:text-slate-300 ml-1">Full Name</label>
            <div class="relative">
            <div class="absolute inset-y-0 left-4 flex items-center text-slate-400">
                <i data-lucide="user" width="18" height="18"></i>
            </div>
            <input
                type="text"
                id="name"
                required
                class="w-full pl-12 pr-4 py-3.5 rounded-2xl bg-slate-50 dark:bg-slate-800 border-2 border-transparent focus:border-[#1a73e8] focus:bg-white dark:focus:bg-slate-900 outline-none transition-all dark:text-white"
                placeholder="John Doe"
            />
            </div>
        </div>

        <div class="space-y-2">
            <label class="text-sm font-bold text-slate-700 dark:text-slate-300 ml-1">Email Address</label>
            <div class="relative">
            <div class="absolute inset-y-0 left-4 flex items-center text-slate-400">
                <i data-lucide="mail" width="18" height="18"></i>
            </div>
            <input
                type="email"
                id="email"
                required
                class="w-full pl-12 pr-4 py-3.5 rounded-2xl bg-slate-50 dark:bg-slate-800 border-2 border-transparent focus:border-[#1a73e8] focus:bg-white dark:focus:bg-slate-900 outline-none transition-all dark:text-white"
                placeholder="name@example.com"
            />
            </div>
        </div>

        <div class="space-y-2">
            <label class="text-sm font-bold text-slate-700 dark:text-slate-300 ml-1">Password</label>
            <div class="relative">
            <div class="absolute inset-y-0 left-4 flex items-center text-slate-400">
                <i data-lucide="lock" width="18" height="18"></i>
            </div>
            <input
                type="password"
                id="password"
                required
                class="w-full pl-12 pr-4 py-3.5 rounded-2xl bg-slate-50 dark:bg-slate-800 border-2 border-transparent focus:border-[#1a73e8] focus:bg-white dark:focus:bg-slate-900 outline-none transition-all dark:text-white"
                placeholder="••••••••"
            />
            </div>
        </div>

        <div class="space-y-2">
            <label class="text-sm font-bold text-slate-700 dark:text-slate-300 ml-1">Role</label>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                <button type="button" onclick="setRole('public')" id="roleBtn-public" class="role-btn py-3 rounded-2xl font-bold text-xs uppercase tracking-wider transition-all border-2 bg-[#1a73e8] text-white border-[#1a73e8] shadow-lg">public</button>
                <button type="button" onclick="setRole('court_staff')" id="roleBtn-court_staff" class="role-btn py-3 rounded-2xl font-bold text-xs uppercase tracking-wider transition-all border-2 bg-slate-50 dark:bg-slate-800 text-slate-500 border-transparent hover:border-slate-200">court staff</button>
                <button type="button" onclick="setRole('lawyer')" id="roleBtn-lawyer" class="role-btn py-3 rounded-2xl font-bold text-xs uppercase tracking-wider transition-all border-2 bg-slate-50 dark:bg-slate-800 text-slate-500 border-transparent hover:border-slate-200">lawyer</button>
                <button type="button" onclick="setRole('admin')" id="roleBtn-admin" class="role-btn py-3 rounded-2xl font-bold text-xs uppercase tracking-wider transition-all border-2 bg-slate-50 dark:bg-slate-800 text-slate-500 border-transparent hover:border-slate-200">admin</button>
            </div>
            <input type="hidden" id="role" value="public" />
        </div>


        <button
            type="submit"
            id="submitBtn"
            class="w-full py-4 mt-4 bg-slate-900 dark:bg-[#1a73e8] text-white rounded-2xl font-bold hover:opacity-90 transition-all shadow-xl flex items-center justify-center gap-2"
        >
            <span id="btnText">Create Account</span>
            <i data-lucide="user-plus" width="20" height="20" id="btnIcon"></i>
            <div id="btnSpinner" class="hidden w-6 h-6 border-4 border-white border-t-transparent rounded-full animate-spin"></div>
        </button>
        </form>

        <p class="mt-8 text-center text-slate-500 dark:text-slate-400 font-medium">
        Already have an account? 
        <a href="/login" class="text-[#1a73e8] dark:text-[#8ab4f8] hover:underline font-bold">Sign In</a>
        </p>
    </div>
    </div>
</div>

<style>
@keyframes scaleIn {
    from { opacity: 0; transform: scale(0.95); }
    to { opacity: 1; transform: scale(1); }
}
.animate-scale-in {
    animation: scaleIn 0.3s ease-out forwards;
}
</style>

<script>
function setRole(role) {
    document.getElementById('role').value = role;
    const roles = ['public', 'court_staff', 'lawyer', 'admin'];

    
    roles.forEach(r => {
        const btn = document.getElementById(`roleBtn-${r}`);
        if(r === role) {
            btn.className = "role-btn py-3 rounded-2xl font-bold text-xs uppercase tracking-wider transition-all border-2 bg-[#1a73e8] text-white border-[#1a73e8] shadow-lg";
        } else {
            btn.className = "role-btn py-3 rounded-2xl font-bold text-xs uppercase tracking-wider transition-all border-2 bg-slate-50 dark:bg-slate-800 text-slate-500 border-transparent hover:border-slate-200";
        }
    });
}

async function handleRegisterSubmit(e) {
    e.preventDefault();
    const name = document.getElementById('name').value;
    const email = document.getElementById('email').value;
    const password = document.getElementById('password').value;
    const role = document.getElementById('role').value;
    
    // UI Loading state
    const btnText = document.getElementById('btnText');
    const btnIcon = document.getElementById('btnIcon');
    const btnSpinner = document.getElementById('btnSpinner');
    const submitBtn = document.getElementById('submitBtn');
    const errorContainer = document.getElementById('error-container');
    const errorText = document.getElementById('error-text');
    
    submitBtn.disabled = true;
    btnText.classList.add('hidden');
    btnIcon.classList.add('hidden');
    btnSpinner.classList.remove('hidden');
    errorContainer.classList.add('hidden');

    try {
        const res = await fetch('/api/users/register', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name, email, password, role })
        });
        const data = await res.json();
        
        if (res.ok) {
            localStorage.setItem('token', data.token);
            localStorage.setItem('user', JSON.stringify({
                id: data._id,
                name: data.name,
                email: data.email,
                role: data.role
            }));
            window.location.href = '/';
        } else {
            errorText.textContent = data.message || 'Registration failed';
            errorContainer.classList.remove('hidden');
        }
    } catch (err) {
        errorText.textContent = 'Network error occurred';
        errorContainer.classList.remove('hidden');
    }

    // Reset UI
    submitBtn.disabled = false;
    btnText.classList.remove('hidden');
    btnIcon.classList.remove('hidden');
    btnSpinner.classList.add('hidden');
}
</script>
