<div class="flex justify-center items-center py-10">
    <div class="w-full max-w-lg animate-scale-in">
    <div class="bg-white dark:bg-[#001E2B] p-10 rounded-2xl border border-[#E8EDEB] dark:border-[#1C2D38] shadow-2xl shadow-[#00ED64]/5">
        <div class="flex flex-col items-center mb-8 text-center">
            <div class="p-3 bg-[#00ED64]/10 rounded-xl mb-4">
                <i data-lucide="user-plus" class="text-[#00ED64]" width="32" height="32"></i>
            </div>
            <h2 class="text-3xl font-black dark:text-white mb-1 tracking-tight">Provision Identity</h2>
            <p class="text-slate-500 dark:text-[#889397] font-bold text-[10px] uppercase tracking-widest">Register New Network Node</p>
        </div>

        <div id="error-container" class="hidden mb-6 p-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-900/30 rounded-lg flex items-center gap-3 text-red-600 dark:text-red-400 text-xs font-bold uppercase tracking-wider animate-shake">
            <i data-lucide="alert-circle" width="16" height="16"></i>
            <span id="error-text"></span>
        </div>

        <form id="registerForm" onsubmit="handleRegisterSubmit(event)" class="space-y-5">
        <div class="space-y-2">
            <label class="text-[10px] font-black uppercase text-slate-500 dark:text-[#889397] tracking-widest ml-1">Full Name</label>
            <div class="relative">
            <div class="absolute inset-y-0 left-4 flex items-center text-slate-400">
                <i data-lucide="user" width="16" height="16"></i>
            </div>
            <input
                type="text"
                id="name"
                required
                class="w-full pl-12 pr-4 py-3 rounded-lg bg-slate-50 dark:bg-[#023448]/30 border border-[#E8EDEB] dark:border-[#1C2D38] focus:border-[#00ED64] outline-none transition-all dark:text-white font-medium text-sm"
                placeholder="Node Administrator"
            />
            </div>
        </div>

        <div class="space-y-2">
            <label class="text-[10px] font-black uppercase text-slate-500 dark:text-[#889397] tracking-widest ml-1">Email Endpoint</label>
            <div class="relative">
            <div class="absolute inset-y-0 left-4 flex items-center text-slate-400">
                <i data-lucide="mail" width="16" height="16"></i>
            </div>
            <input
                type="email"
                id="email"
                required
                class="w-full pl-12 pr-4 py-3 rounded-lg bg-slate-50 dark:bg-[#023448]/30 border border-[#E8EDEB] dark:border-[#1C2D38] focus:border-[#00ED64] outline-none transition-all dark:text-white font-medium text-sm"
                placeholder="admin@ecourt.io"
            />
            </div>
        </div>

        <div class="space-y-2">
            <label class="text-[10px] font-black uppercase text-slate-500 dark:text-[#889397] tracking-widest ml-1">Access Key</label>
            <div class="relative">
            <div class="absolute inset-y-0 left-4 flex items-center text-slate-400">
                <i data-lucide="lock" width="16" height="16"></i>
            </div>
            <input
                type="password"
                id="password"
                required
                class="w-full pl-12 pr-4 py-3 rounded-lg bg-slate-50 dark:bg-[#023448]/30 border border-[#E8EDEB] dark:border-[#1C2D38] focus:border-[#00ED64] outline-none transition-all dark:text-white font-medium text-sm"
                placeholder="••••••••"
            />
            </div>
        </div>

        <div class="space-y-2">
            <label class="text-[10px] font-black uppercase text-slate-500 dark:text-[#889397] tracking-widest ml-1">System Role</label>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
                <button type="button" onclick="setRole('public')" id="roleBtn-public" class="role-btn py-2.5 rounded-lg font-black text-[10px] uppercase tracking-wider transition-all border border-[#00ED64] bg-[#00ED64] text-[#001E2B] shadow-lg shadow-[#00ED64]/10">Public</button>
                <button type="button" onclick="setRole('court_staff')" id="roleBtn-court_staff" class="role-btn py-2.5 rounded-lg font-black text-[10px] uppercase tracking-wider transition-all border border-[#E8EDEB] dark:border-[#1C2D38] bg-slate-50 dark:bg-[#023448]/30 text-slate-500 hover:border-[#00ED64]">Staff</button>
                <button type="button" onclick="setRole('lawyer')" id="roleBtn-lawyer" class="role-btn py-2.5 rounded-lg font-black text-[10px] uppercase tracking-wider transition-all border border-[#E8EDEB] dark:border-[#1C2D38] bg-slate-50 dark:bg-[#023448]/30 text-slate-500 hover:border-[#00ED64]">Lawyer</button>
                <button type="button" onclick="setRole('admin')" id="roleBtn-admin" class="role-btn py-2.5 rounded-lg font-black text-[10px] uppercase tracking-wider transition-all border border-[#E8EDEB] dark:border-[#1C2D38] bg-slate-50 dark:bg-[#023448]/30 text-slate-500 hover:border-[#00ED64]">Admin</button>
            </div>
            <input type="hidden" id="role" value="public" />
        </div>

        <button
            type="submit"
            id="submitBtn"
            class="w-full py-4 mt-4 bg-[#00ED64] text-[#001E2B] rounded-lg font-black text-xs uppercase tracking-widest hover:bg-[#00D158] transition-all shadow-lg shadow-[#00ED64]/10 flex items-center justify-center gap-2"
        >
            <span id="btnText">Provision Identity</span>
            <i data-lucide="arrow-right" width="16" height="16" id="btnIcon"></i>
            <div id="btnSpinner" class="hidden w-5 h-5 border-2 border-[#001E2B] border-t-transparent rounded-full animate-spin"></div>
        </button>
        </form>

        <div class="mt-8 flex flex-col items-center gap-4">
            <p class="text-xs font-bold text-slate-500 dark:text-[#889397] uppercase tracking-widest">
                Already Registered? 
                <a href="/login" class="text-[#00ED64] hover:underline font-black ml-1">Connect Node</a>
            </p>
            <div class="w-12 h-0.5 bg-[#E8EDEB] dark:bg-[#1C2D38] rounded-full"></div>
            <p class="text-[9px] text-slate-400 font-medium uppercase tracking-[0.2em]">Legal Data Cloud Platform</p>
        </div>
    </div>
    </div>
</div>

<script>
function setRole(role) {
    document.getElementById('role').value = role;
    const roles = ['public', 'court_staff', 'lawyer', 'admin'];
    
    roles.forEach(r => {
        const btn = document.getElementById(`roleBtn-${r}`);
        if(r === role) {
            btn.className = "role-btn py-2.5 rounded-lg font-black text-[10px] uppercase tracking-wider transition-all border border-[#00ED64] bg-[#00ED64] text-[#001E2B] shadow-lg shadow-[#00ED64]/10";
        } else {
            btn.className = "role-btn py-2.5 rounded-lg font-black text-[10px] uppercase tracking-wider transition-all border border-[#E8EDEB] dark:border-[#1C2D38] bg-slate-50 dark:bg-[#023448]/30 text-slate-500 hover:border-[#00ED64]";
        }
    });
}

async function handleRegisterSubmit(e) {
    e.preventDefault();
    const name = document.getElementById('name').value;
    const email = document.getElementById('email').value;
    const password = document.getElementById('password').value;
    const role = document.getElementById('role').value;
    
    // UI Loading state
    const btnText = document.getElementById('btnText');
    const btnIcon = document.getElementById('btnIcon');
    const btnSpinner = document.getElementById('btnSpinner');
    const submitBtn = document.getElementById('submitBtn');
    const errorContainer = document.getElementById('error-container');
    const errorText = document.getElementById('error-text');
    
    submitBtn.disabled = true;
    btnText.classList.add('hidden');
    btnIcon.classList.add('hidden');
    btnSpinner.classList.remove('hidden');
    errorContainer.classList.add('hidden');

    try {
        const res = await fetch('/api/users/register', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name, email, password, role })
        });
        const data = await res.json();
        
        if (res.ok) {
            localStorage.setItem('token', data.token);
            localStorage.setItem('user', JSON.stringify({
                id: data._id,
                name: data.name,
                email: data.email,
                role: data.role
            }));
            window.location.href = '/';
        } else {
            errorText.textContent = data.message || 'Registration failed';
            errorContainer.classList.remove('hidden');
        }
    } catch (err) {
        errorText.textContent = 'Network error occurred';
        errorContainer.classList.remove('hidden');
    }

    // Reset UI
    submitBtn.disabled = false;
    btnText.classList.remove('hidden');
    btnIcon.classList.remove('hidden');
    btnSpinner.classList.add('hidden');
}
</script>
