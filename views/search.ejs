<div class="max-w-6xl mx-auto space-y-8">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 bg-white dark:bg-[#001E2B] p-8 rounded-2xl border border-[#E8EDEB] dark:border-[#1C2D38] shadow-sm">
        <div>
            <h1 class="text-2xl font-black dark:text-white tracking-tight mb-1">Index Query</h1>
            <p class="text-[10px] font-black uppercase text-slate-500 dark:text-[#889397] tracking-widest">
                Found <span id="resultCount" class="text-[#00ED64]">0</span> Documents for "<span id="displayQuery" class="text-[#00ED64]"></span>"
            </p>
        </div>
        <form onsubmit="handleSearch(event)" class="flex-1 max-w-xl relative group">
        <div class="absolute inset-y-0 left-5 flex items-center text-slate-400">
            <i data-lucide="search" width="18" height="18"></i>
        </div>
        <input
            type="text"
            id="searchInput"
            class="w-full pl-14 pr-32 py-4 rounded-lg bg-slate-50 dark:bg-[#023448]/30 border border-[#E8EDEB] dark:border-[#1C2D38] focus:border-[#00ED64] outline-none transition-all text-sm font-bold dark:text-white placeholder-slate-400"
            placeholder="Query Case UUID or Identifier"
        />
        <button 
            type="submit"
            class="absolute right-2 top-2 bottom-2 px-6 bg-[#00ED64] text-[#001E2B] rounded-md text-[10px] font-black uppercase tracking-widest hover:bg-[#00D158] transition-all shadow-lg shadow-[#00ED64]/10"
        >
            Execute
        </button>
        </form>
    </div>

    <div id="loadingSkel" class="grid grid-cols-1 md:grid-cols-2 gap-6 hidden">
        <div class="h-48 rounded-2xl bg-slate-50 dark:bg-[#023448]/20 border border-[#E8EDEB] dark:border-[#1C2D38] animate-pulse"></div>
        <div class="h-48 rounded-2xl bg-slate-50 dark:bg-[#023448]/20 border border-[#E8EDEB] dark:border-[#1C2D38] animate-pulse"></div>
    </div>

    <div id="resultsGrid" class="grid grid-cols-1 md:grid-cols-2 gap-6 hidden">
        <!-- Populated by JS -->
    </div>

    <div id="noResultsMsg" class="hidden text-center py-24 bg-white dark:bg-[#001E2B] rounded-2xl border border-[#E8EDEB] dark:border-[#1C2D38]">
        <div class="w-16 h-16 bg-slate-50 dark:bg-[#023448]/30 rounded-full flex items-center justify-center mx-auto mb-6 text-slate-300">
            <i data-lucide="database-zap" width="32" height="32"></i>
        </div>
        <h2 class="text-xl font-black mb-2 dark:text-white tracking-tight uppercase">Null Set Returned</h2>
        <p class="text-xs font-bold text-slate-500 dark:text-[#889397] uppercase tracking-widest">No documents matching your query predicates found.</p>
        <a href="/" class="inline-block mt-8 text-[10px] font-black text-[#00ED64] uppercase tracking-[0.2em] border-b-2 border-transparent hover:border-[#00ED64] transition-all">Reset Query Context</a>
    </div>

    <div id="errorMsg" class="hidden text-center py-20 bg-red-50 dark:bg-red-900/10 rounded-2xl border border-red-100 dark:border-red-900/20 text-red-500 font-black text-xs uppercase tracking-widest">
        Critical Exception: Data Retrieval Failed
    </div>
</div>


<style>
@keyframes slideUpFade {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
}
.animate-slide-up-fade {
    animation: slideUpFade 0.4s ease-out forwards;
    opacity: 0;
}
</style>

<script src="/js/search.js"></script>
