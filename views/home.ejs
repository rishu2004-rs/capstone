        <div class="p-12 rounded-[2rem] bg-[#f1f3f4] dark:bg-[#292a2d] transition-all h-full flex flex-col items-center text-center hover:bg-[#e8eaed] dark:hover:bg-[#3c4043]">
        <div class="w-20 h-20 rounded-full bg-white dark:bg-[#202124] flex items-center justify-center mb-8 shadow-sm">
            <i data-lucide="shield" class="text-[#188038] dark:text-[#81c995]" width="36" height="36" stroke-width="1.5"></i>
        </div>
        <h3 class="text-2xl font-medium mb-4 text-[#202124] dark:text-[#e8eaed]">Secure Documentation</h3>
        <p class="text-[#5f6368] dark:text-[#9aa0a6] text-lg leading-relaxed">
            Encrypted and authenticated access to case documents and hearing records.
        </p>
