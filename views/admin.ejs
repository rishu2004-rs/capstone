<script>
    document.addEventListener('DOMContentLoaded', () => {
        const userStr = localStorage.getItem('user');
        if (!userStr) {
            window.location.href = '/login';
            return;
        }

        const user = JSON.parse(userStr);
        if (user.role !== 'admin') {
            window.location.href = '/';
        }
    });
</script>
