<div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Left Column - Core Info -->
    <div class="lg:col-span-2 space-y-6">
        <div id="loadingIndicator" class="flex justify-center items-center h-[60vh]">
            <div class="w-10 h-10 border-4 border-[#00ED64] border-t-transparent rounded-full animate-spin"></div>
        </div>

        <div id="notFoundMsg" class="hidden text-center py-20 bg-white dark:bg-[#001E2B] rounded-2xl border border-[#E8EDEB] dark:border-[#1C2D38]">
            <i data-lucide="database-zap" class="mx-auto text-slate-300 mb-4" width="48" height="48"></i>
            <p class="text-slate-500 font-bold uppercase tracking-widest text-xs">Document Not Found</p>
        </div>

        <div id="mainContent" class="hidden space-y-6">
            <div class="bg-white dark:bg-[#001E2B] p-10 rounded-2xl border border-[#E8EDEB] dark:border-[#1C2D38] shadow-sm animate-fade-in">
                <div class="flex flex-wrap items-center justify-between gap-6 mb-10 border-b border-[#E8EDEB] dark:border-[#1C2D38] pb-10">
                    <div>
                        <div class="flex items-center gap-2 mb-3">
                            <span class="p-1 bg-[#00ED64]/10 rounded">
                                <i data-lucide="hash" class="text-[#00ED64]" width="12" height="12"></i>
                            </span>
                            <span id="caseNumber" class="text-[10px] font-black text-[#889397] uppercase tracking-[0.2em]"></span>
                        </div>
                        <h1 id="caseTitle" class="text-4xl font-black dark:text-white tracking-tight"></h1>
                    </div>
                    <div id="statusBadgeContainer"></div>
                </div>

                <div class="mb-10">
                    <span class="text-[10px] font-black text-slate-400 dark:text-[#889397] uppercase tracking-widest block mb-4">Description Object</span>
                    <p id="caseDescription" class="text-slate-600 dark:text-[#889397] leading-relaxed text-lg font-medium"></p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 pt-10 border-t border-[#E8EDEB] dark:border-[#1C2D38]">
                    <div class="space-y-6">
                        <div class="flex items-start gap-4 p-4 rounded-xl bg-slate-50 dark:bg-[#023448]/30 border border-[#E8EDEB] dark:border-[#1C2D38]">
                            <div class="p-2.5 bg-white dark:bg-[#001E2B] text-slate-400 rounded-lg border border-[#E8EDEB] dark:border-[#1C2D38]"><i data-lucide="user" width="18" height="18"></i></div>
                            <div>
                                <p class="text-[9px] uppercase font-black text-slate-400 tracking-widest mb-1">Petitioner</p>
                                <p id="casePetitioner" class="font-bold dark:text-white text-base"></p>
                            </div>
                        </div>
                        <div class="flex items-start gap-4 p-4 rounded-xl bg-slate-50 dark:bg-[#023448]/30 border border-[#E8EDEB] dark:border-[#1C2D38]">
                            <div class="p-2.5 bg-white dark:bg-[#001E2B] text-slate-400 rounded-lg border border-[#E8EDEB] dark:border-[#1C2D38]"><i data-lucide="user" width="18" height="18"></i></div>
                            <div>
                                <p class="text-[9px] uppercase font-black text-slate-400 tracking-widest mb-1">Respondent</p>
                                <p id="caseRespondent" class="font-bold dark:text-white text-base"></p>
                            </div>
                        </div>
                    </div>
                    <div class="space-y-6">
                        <div class="flex items-start gap-4 p-4 rounded-xl bg-slate-50 dark:bg-[#023448]/30 border border-[#E8EDEB] dark:border-[#1C2D38]">
                            <div class="p-2.5 bg-white dark:bg-[#001E2B] text-slate-400 rounded-lg border border-[#E8EDEB] dark:border-[#1C2D38]"><i data-lucide="map-pin" width="18" height="18"></i></div>
                            <div>
                                <p class="text-[9px] uppercase font-black text-slate-400 tracking-widest mb-1">Court Jurisdiction</p>
                                <p id="caseCourtName" class="font-bold dark:text-white text-base"></p>
                            </div>
                        </div>
                        <div class="flex items-start gap-4 p-4 rounded-xl bg-slate-50 dark:bg-[#023448]/30 border border-[#E8EDEB] dark:border-[#1C2D38]">
                            <div class="p-2.5 bg-white dark:bg-[#001E2B] text-[#00ED64] rounded-lg border border-[#E8EDEB] dark:border-[#1C2D38]"><i data-lucide="calendar" width="18" height="18"></i></div>
                            <div>
                                <p class="text-[9px] uppercase font-black text-slate-400 tracking-widest mb-1">Sync Date / Hearing</p>
                                <p id="caseHearingDate" class="font-bold dark:text-white text-base"></p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Timeline -->
            <div class="bg-white dark:bg-[#001E2B] p-8 rounded-2xl border border-[#E8EDEB] dark:border-[#1C2D38] shadow-sm">
                <div class="flex items-center gap-3 mb-8">
                    <i data-lucide="activity" class="text-[#00ED64]" width="20" height="20"></i>
                    <h2 class="text-sm font-black dark:text-white uppercase tracking-widest">Document Event Stream</h2>
                </div>
                
                <div id="historyTimeline" class="space-y-6 relative before:absolute before:left-[11px] before:top-2 before:bottom-2 before:w-[1px] before:bg-[#E8EDEB] dark:before:bg-[#1C2D38]">
                    <!-- Populated by JS -->
                </div>
            </div>
        </div>
    </div>

    <!-- Right Column -->
    <div class="space-y-6 hidden" id="sidebarArea">
        <!-- Management -->
        <div id="managementCard" class="hidden bg-[#001E2B] text-white p-8 rounded-2xl border border-[#1C2D38] shadow-xl animate-fade-in">
            <div class="flex items-center gap-3 mb-8">
                <div class="p-2 bg-[#00ED64]/10 rounded">
                    <i data-lucide="terminal" class="text-[#00ED64]" width="18" height="18"></i>
                </div>
                <h3 class="text-sm font-black uppercase tracking-widest">Update State</h3>
            </div>
            
            <form id="updateForm" onsubmit="handleUpdateStatus(event)" class="space-y-6">
                <div class="space-y-2">
                    <label class="text-[9px] uppercase font-black text-[#889397] tracking-[0.2em] ml-1">New State</label>
                    <select id="updateStatus" class="w-full px-4 py-3 rounded-lg bg-[#023448]/50 border border-[#1C2D38] text-white outline-none focus:border-[#00ED64] transition-all text-xs font-bold uppercase tracking-wider">
                        <option value="Pending">Pending</option>
                        <option value="In Progress">In Progress</option>
                        <option value="Hearing Scheduled">Scheduled</option>
                        <option value="Closed">Closed</option>
                    </select>
                </div>
                <div class="space-y-2">
                    <label class="text-[9px] uppercase font-black text-[#889397] tracking-[0.2em] ml-1">Update Date</label>
                    <input type="date" id="updateHearingDate" class="w-full px-4 py-3 rounded-lg bg-[#023448]/50 border border-[#1C2D38] text-white outline-none focus:border-[#00ED64] transition-all text-xs font-bold" />
                </div>
                <button type="submit" id="updateBtn" class="w-full py-3.5 bg-[#00ED64] text-[#001E2B] rounded-lg font-black text-[10px] uppercase tracking-[0.2em] hover:bg-[#00D158] transition-all shadow-lg shadow-[#00ED64]/10">
                    Commit Update
                </button>
            </form>
        </div>

        <!-- QR -->
        <div class="bg-white dark:bg-[#001E2B] p-8 rounded-2xl border border-[#E8EDEB] dark:border-[#1C2D38] shadow-sm">
            <div class="flex items-center gap-3 mb-6">
                <i data-lucide="qr-code" class="text-[#889397]" width="18" height="18"></i>
                <h3 class="text-sm font-black dark:text-white uppercase tracking-widest">Access Pointer</h3>
            </div>
            
            <div id="qrContainer" class="flex flex-col items-center justify-center p-6 bg-slate-50 dark:bg-[#023448]/30 rounded-xl border border-dashed border-[#E8EDEB] dark:border-[#1C2D38]">
                <div id="qrLoading" class="py-8">
                    <div class="w-6 h-6 border-2 border-[#00ED64] border-t-transparent rounded-full animate-spin"></div>
                </div>
                <img id="qrImage" class="hidden w-40 h-40 rounded-lg shadow-sm mb-4 border-4 border-white" src="" alt="Case QR Code">
                <p class="text-[9px] uppercase font-black text-slate-400 tracking-widest text-center">Node Address Verification</p>
            </div>
            
            <button onclick="window.print()" class="w-full mt-6 py-3 px-4 bg-slate-100 dark:bg-[#023448] text-slate-600 dark:text-[#889397] rounded-lg font-black text-[10px] uppercase tracking-widest hover:bg-[#00ED64] hover:text-[#001E2B] transition-all flex items-center justify-center gap-2">
                <i data-lucide="printer" width="14" height="14"></i>
                Export Document
            </button>
        </div>

        <!-- Docs -->
        <div id="docsCard" class="bg-white dark:bg-[#001E2B] p-8 rounded-2xl border border-[#E8EDEB] dark:border-[#1C2D38] shadow-sm">
            <div class="flex items-center gap-3 mb-6">
                <i data-lucide="file-text" class="text-[#00ED64]" width="18" height="18"></i>
                <h3 class="text-sm font-black dark:text-white uppercase tracking-widest">File Attachments</h3>
            </div>

            <div id="documentsList" class="space-y-3 mb-8">
                <!-- Populated by JS -->
            </div>

            <form id="uploadDocForm" onsubmit="handleUploadDoc(event)" class="hidden space-y-4 pt-6 border-t border-[#E8EDEB] dark:border-[#1C2D38]">
                <input type="text" id="docName" placeholder="Document Name" required class="w-full px-4 py-2.5 rounded-lg bg-slate-50 dark:bg-[#023448]/30 border border-[#E8EDEB] dark:border-[#1C2D38] focus:border-[#00ED64] outline-none transition-all dark:text-white text-xs font-bold" />
                <input type="text" id="docUrl" placeholder="External URL" required class="w-full px-4 py-2.5 rounded-lg bg-slate-50 dark:bg-[#023448]/30 border border-[#E8EDEB] dark:border-[#1C2D38] focus:border-[#00ED64] outline-none transition-all dark:text-white text-xs font-bold" />
                <button type="submit" class="w-full py-3 bg-[#00ED64] text-[#001E2B] rounded-lg font-black text-[10px] uppercase tracking-widest hover:bg-[#00D158] transition-all flex items-center justify-center gap-2">
                    <i data-lucide="plus-square" width="14" height="14"></i>
                    Attach Document
                </button>
            </form>
        </div>
    </div>
</div>

</div>

<!-- Chat Drawer Container -->
<div id="chatDrawer" class="fixed inset-y-0 right-0 w-full sm:w-[450px] bg-white dark:bg-slate-900 shadow-2xl z-[100] transition-all duration-300 ease-in-out border-l border-slate-100 dark:border-slate-800 flex flex-col">

    <!-- Chat Header -->
    <div class="px-8 py-6 border-b border-slate-100 dark:border-slate-800 flex items-center justify-between bg-slate-50 dark:bg-slate-800/50">
        <div class="flex items-center gap-4">
            <div class="p-3 bg-blue-50 dark:bg-blue-900/20 text-[#1a73e8] dark:text-[#8ab4f8] rounded-2xl">
                <i data-lucide="message-square" width="24" height="24"></i>
            </div>
            <div>
                <h3 class="text-xl font-black dark:text-white">Legal Chat</h3>
                <p class="text-[10px] uppercase font-black text-slate-400 tracking-widest">Case ID: <span id="chatCaseNum"></span></p>
            </div>
        </div>
        <button onclick="toggleChat()" class="p-4 hover:bg-slate-200 dark:hover:bg-slate-700 rounded-2xl transition-all">
            <i data-lucide="x" width="24" height="24" class="dark:text-white"></i>
        </button>
    </div>

    <!-- Messages Area -->
    <div id="chatMessages" class="flex-grow overflow-y-auto p-8 space-y-6">
        <div class="flex justify-center py-10">
            <div class="w-8 h-8 border-4 border-[#1a73e8] border-t-transparent rounded-full animate-spin"></div>
        </div>
    </div>

    <!-- Chat Input -->
    <div class="p-8 border-t border-slate-100 dark:border-slate-800">
        <form id="chatForm" onsubmit="handleChatSubmit(event)" class="relative">
            <input type="text" id="chatInput" placeholder="Type your message..." class="w-full pl-6 pr-16 py-5 bg-slate-100 dark:bg-slate-800 rounded-[2rem] border-none outline-none focus:ring-2 ring-[#1a73e8] dark:text-white font-medium" />
            <button type="submit" class="absolute right-2 top-2 bottom-2 px-6 bg-[#1a73e8] text-white rounded-[1.5rem] font-bold hover:bg-[#1557b0] transition-all flex items-center justify-center">
                <i data-lucide="send" width="20" height="20"></i>
            </button>
        </form>
    </div>
</div>

<!-- Floating Chat Button -->
<button id="chatTrigger" onclick="toggleChat()" class="fixed hidden bottom-10 right-10 p-6 bg-[#1a73e8] text-white rounded-[2.5rem] shadow-2xl shadow-[#1a73e8]/40 hover:scale-110 active:scale-95 transition-all z-40 group">
    <div class="flex items-center gap-3">
        <i data-lucide="message-square" width="28" height="28"></i>
        <span class="max-w-0 overflow-hidden group-hover:max-w-xs transition-all duration-300 font-extrabold whitespace-nowrap">Open Case Chat</span>
    </div>
</button>


<style>
@keyframes slideInLeft {
    from { opacity: 0; transform: translateX(-20px); }
    to { opacity: 1; transform: translateX(0); }
}
.animate-slide-in-left {
    animation: slideInLeft 0.5s ease-out forwards;
}

@keyframes slideInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
}
.animate-slide-in-up {
    animation: slideInUp 0.5s ease-out forwards;
    opacity: 0; /* Starts invisible before animation */
}

#chatDrawer {
    transition: right 0.3s ease-in-out;
    right: -100%;
}
@media (min-width: 640px) {
    #chatDrawer { right: -450px; }
}
#chatDrawer.open {
    right: 0 !important;
}
</style>

<script>
    const CASE_ID = "<%= caseId %>";

    function toggleChat() {
        console.log("Toggle Chat Clicked");
        const drawer = document.getElementById('chatDrawer');
        if (!drawer) return;
        
        drawer.classList.toggle('open');
        
        if (drawer.classList.contains('open')) {
            if (typeof initSocket === 'function') initSocket();
            if (typeof fetchMessages === 'function') fetchMessages();
        }
    }
</script>

<script src="/js/case-details.js"></script>
