<div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-10">
    <!-- Left Column - Core Info -->
    <div class="lg:col-span-2 space-y-8">
        <div id="loadingIndicator" class="flex justify-center items-center h-[60vh]">
            <div class="w-12 h-12 border-4 border-[#1a73e8] border-t-transparent rounded-full animate-spin"></div>
        </div>

        <div id="notFoundMsg" class="hidden text-center py-20 font-bold text-slate-500">
            Case not found.
        </div>

        <div id="mainContent" class="hidden">
            <div class="bg-white dark:bg-slate-900 p-8 md:p-12 rounded-[3.5rem] border border-slate-100 dark:border-slate-800 shadow-xl shadow-slate-200/50 dark:shadow-none animate-slide-in-left">
                <div class="flex flex-wrap items-center justify-between gap-6 mb-10">
                    <div>
                        <div id="caseNumber" class="inline-block px-4 py-1 bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 rounded-full text-xs font-black uppercase tracking-[0.2em] mb-3"></div>
                        <h1 id="caseTitle" class="text-4xl font-black dark:text-white tracking-tight"></h1>
                    </div>
                    <div id="statusBadgeContainer"></div>
                </div>

                <p id="caseDescription" class="text-slate-600 dark:text-slate-400 leading-[1.8] text-lg mb-10 pb-10 border-b border-slate-50 dark:border-slate-800"></p>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8">
                    <div class="space-y-6">
                        <div class="flex items-center gap-4">
                            <div class="p-3 bg-red-50 dark:bg-red-900/20 text-red-500 rounded-2xl"><i data-lucide="user" width="20" height="20"></i></div>
                            <div>
                                <p class="text-[10px] uppercase font-black text-slate-400 tracking-widest">Petitioner</p>
                                <p id="casePetitioner" class="font-bold dark:text-white text-lg"></p>
                            </div>
                        </div>
                        <div class="flex items-center gap-4">
                            <div class="p-3 bg-blue-50 dark:bg-blue-900/20 text-blue-500 rounded-2xl"><i data-lucide="user" width="20" height="20"></i></div>
                            <div>
                                <p class="text-[10px] uppercase font-black text-slate-400 tracking-widest">Respondent</p>
                                <p id="caseRespondent" class="font-bold dark:text-white text-lg"></p>
                            </div>
                        </div>
                    </div>
                    <div class="space-y-6">
                        <div class="flex items-center gap-4">
                            <div class="p-3 bg-[#f1f3f4] dark:bg-[#e8eaed]/10 text-[#1a73e8] dark:text-[#8ab4f8] rounded-2xl"><i data-lucide="map-pin" width="20" height="20"></i></div>
                            <div>
                                <p class="text-[10px] uppercase font-black text-slate-400 tracking-widest">Court Location</p>
                                <p id="caseCourtName" class="font-bold dark:text-white text-lg"></p>
                            </div>
                        </div>
                        <div class="flex items-center gap-4">
                            <div class="p-3 bg-emerald-50 dark:bg-emerald-900/20 text-emerald-500 rounded-2xl"><i data-lucide="calendar" width="20" height="20"></i></div>
                            <div>
                                <p class="text-[10px] uppercase font-black text-slate-400 tracking-widest">Next Hearing</p>
                                <p id="caseHearingDate" class="font-bold dark:text-white text-lg"></p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Dynamic History Timeline -->
            <div class="bg-white dark:bg-slate-900 p-10 rounded-[3rem] border border-slate-100 dark:border-slate-800 shadow-sm mt-8">
                <div class="flex items-center gap-3 mb-10">
                    <i data-lucide="history" class="text-[#1a73e8] dark:text-[#8ab4f8]" width="24" height="24"></i>
                    <h2 class="text-2xl font-black dark:text-white">Case History</h2>
                </div>
                
                <div id="historyTimeline" class="space-y-8 relative before:absolute before:left-[11px] before:top-2 before:bottom-2 before:w-[2px] before:bg-slate-100 dark:before:bg-slate-800">
                    <!-- Populated by JS -->
                </div>
            </div>
        </div>
    </div>

    <!-- Right Column - Actions & Docs -->
    <div class="space-y-8 hidden" id="sidebarArea">
        <!-- Management Card (Admin/Staff only) -->
        <div id="managementCard" class="hidden bg-slate-900 dark:bg-slate-800 text-white p-10 rounded-[3rem] shadow-2xl shadow-slate-900/40 animate-slide-in-up">
            <div class="flex items-center gap-3 mb-8">
                <i data-lucide="refresh-cw" class="text-[#8ab4f8]" width="24" height="24"></i>
                <h3 class="text-xl font-black">Management</h3>
            </div>
            
            <form id="updateForm" onsubmit="handleUpdateStatus(event)" class="space-y-6">
                <div class="space-y-2">
                    <label class="text-[10px] uppercase font-black text-slate-400 tracking-widest">Update Status</label>
                    <select id="updateStatus" class="w-full px-5 py-4 rounded-2xl bg-slate-800 dark:bg-slate-700 border-none outline-none focus:ring-2 ring-[#8ab4f8] transition-all font-bold text-white">
                        <option value="Pending">Pending</option>
                        <option value="In Progress">In Progress</option>
                        <option value="Hearing Scheduled">Hearing Scheduled</option>
                        <option value="Closed">Closed</option>
                        <option value="Dismissed">Dismissed</option>
                    </select>
                </div>
                <div class="space-y-2">
                    <label class="text-[10px] uppercase font-black text-slate-400 tracking-widest">Hearing Date</label>
                    <input type="date" id="updateHearingDate" class="w-full px-5 py-4 rounded-2xl bg-slate-800 dark:bg-slate-700 border-none outline-none focus:ring-2 ring-[#8ab4f8] transition-all font-bold text-white" />
                </div>
                <button type="submit" id="updateBtn" class="w-full py-4 bg-[#1a73e8] text-white rounded-2xl font-extrabold hover:bg-[#1557b0] transition-all shadow-xl shadow-[#1a73e8]/20 disabled:opacity-50">
                    Commit Changes
                </button>
            </form>
        </div>

        <!-- Documentation Card -->
        <div id="docsCard" class="bg-white dark:bg-slate-900 p-10 rounded-[3rem] border border-slate-100 dark:border-slate-800 shadow-sm animate-slide-in-up" style="animation-delay: 0.1s">
            <div class="flex items-center gap-3 mb-8 text-emerald-500">
                <i data-lucide="file-text" width="24" height="24"></i>
                <h3 class="text-xl font-black dark:text-white">Documents</h3>
            </div>

            <div id="documentsList" class="space-y-4 mb-10">
                <!-- Populated by JS -->
            </div>

            <form id="uploadDocForm" onsubmit="handleUploadDoc(event)" class="hidden space-y-4 pt-6 border-t border-slate-50 dark:border-slate-800">
                <input type="text" id="docName" placeholder="Doc Name" required class="w-full px-5 py-3 rounded-xl bg-slate-50 dark:bg-slate-800 border-none outline-none focus:ring-2 ring-emerald-500/50 transition-all dark:text-white text-sm" />
                <input type="text" id="docUrl" placeholder="URL Link" required class="w-full px-5 py-3 rounded-xl bg-slate-50 dark:bg-slate-800 border-none outline-none focus:ring-2 ring-emerald-500/50 transition-all dark:text-white text-sm" />
                <button type="submit" class="w-full py-3 bg-emerald-500 text-white rounded-xl font-bold hover:bg-emerald-600 transition-all shadow-lg shadow-emerald-500/20 flex items-center justify-center gap-2">
                    <i data-lucide="upload" width="18" height="18"></i>
                    Attach File
                </button>
            </form>
        </div>
    </div>
</div>

<style>
@keyframes slideInLeft {
    from { opacity: 0; transform: translateX(-20px); }
    to { opacity: 1; transform: translateX(0); }
}
.animate-slide-in-left {
    animation: slideInLeft 0.5s ease-out forwards;
}

@keyframes slideInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
}
.animate-slide-in-up {
    animation: slideInUp 0.5s ease-out forwards;
    opacity: 0; /* Starts invisible before animation */
}
</style>

<script>
    const CASE_ID = "<%= caseId %>";
</script>
<script src="/js/case-details.js"></script>
