<div class="flex justify-center items-center py-20">
    <div class="w-full max-w-md animate-scale-in">
    <div class="bg-white dark:bg-[#001E2B] p-10 rounded-2xl border border-[#E8EDEB] dark:border-[#1C2D38] shadow-2xl shadow-[#00ED64]/5">
        <div class="flex flex-col items-center mb-10 text-center">
            <div class="p-3 bg-[#00ED64]/10 rounded-xl mb-4">
                <i data-lucide="lock" class="text-[#00ED64]" width="32" height="32"></i>
            </div>
            <h2 class="text-3xl font-black dark:text-white mb-1 tracking-tight">Access Cluster</h2>
            <p class="text-slate-500 dark:text-[#889397] font-bold text-[10px] uppercase tracking-widest">Authenticated Personnel Only</p>
        </div>

        <div id="error-container" class="hidden mb-6 p-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-900/30 rounded-lg flex items-center gap-3 text-red-600 dark:text-red-400 text-xs font-bold uppercase tracking-wider animate-shake">
            <i data-lucide="alert-circle" width="16" height="16"></i>
            <span id="error-text"></span>
        </div>

        <form id="loginForm" onsubmit="handleLoginSubmit(event)" class="space-y-6">
        <div class="space-y-2">
            <label class="text-[10px] font-black uppercase text-slate-500 dark:text-[#889397] tracking-widest ml-1">Identity Endpoint (Email)</label>
            <div class="relative">
            <div class="absolute inset-y-0 left-4 flex items-center text-slate-400">
                <i data-lucide="mail" width="16" height="16"></i>
            </div>
            <input
                type="email"
                id="email"
                required
                class="w-full pl-12 pr-4 py-3.5 rounded-lg bg-slate-50 dark:bg-[#023448]/30 border border-[#E8EDEB] dark:border-[#1C2D38] focus:border-[#00ED64] outline-none transition-all dark:text-white font-medium text-sm"
                placeholder="operator@ecourt.io"
            />
            </div>
        </div>

        <div class="space-y-2">
            <label class="text-[10px] font-black uppercase text-slate-500 dark:text-[#889397] tracking-widest ml-1">Access Key (Password)</label>
            <div class="relative">
            <div class="absolute inset-y-0 left-4 flex items-center text-slate-400">
                <i data-lucide="key-round" width="16" height="16"></i>
            </div>
            <input
                type="password"
                id="password"
                required
                class="w-full pl-12 pr-4 py-3.5 rounded-lg bg-slate-50 dark:bg-[#023448]/30 border border-[#E8EDEB] dark:border-[#1C2D38] focus:border-[#00ED64] outline-none transition-all dark:text-white font-medium text-sm"
                placeholder="••••••••"
            />
            </div>
        </div>

        <button
            type="submit"
            id="submitBtn"
            class="w-full py-4 bg-[#00ED64] text-[#001E2B] rounded-lg font-black text-xs uppercase tracking-widest hover:bg-[#00D158] transition-all shadow-lg shadow-[#00ED64]/10 flex items-center justify-center gap-2"
        >
            <span id="btnText">Establish Connection</span>
            <i data-lucide="arrow-right" width="16" height="16" id="btnIcon"></i>
            <div id="btnSpinner" class="hidden w-5 h-5 border-2 border-[#001E2B] border-t-transparent rounded-full animate-spin"></div>
        </button>
        </form>

        <div class="mt-8 flex flex-col items-center gap-4">
            <p class="text-xs font-bold text-slate-500 dark:text-[#889397] uppercase tracking-widest">
                New User? 
                <a href="/register" class="text-[#00ED64] hover:underline font-black ml-1">Request Access</a>
            </p>
            <div class="w-12 h-0.5 bg-[#E8EDEB] dark:bg-[#1C2D38] rounded-full"></div>
            <p class="text-[9px] text-slate-400 font-medium uppercase tracking-[0.2em]">Legal Data Cloud Platform</p>
        </div>
    </div>
    </div>
</div>


<style>
@keyframes scaleIn {
    from { opacity: 0; transform: scale(0.95); }
    to { opacity: 1; transform: scale(1); }
}
.animate-scale-in {
    animation: scaleIn 0.3s ease-out forwards;
}
</style>

<script>
async function handleLoginSubmit(e) {
    e.preventDefault();
    const email = document.getElementById('email').value;
    const password = document.getElementById('password').value;
    
    // UI Loading state
    const btnText = document.getElementById('btnText');
    const btnIcon = document.getElementById('btnIcon');
    const btnSpinner = document.getElementById('btnSpinner');
    const submitBtn = document.getElementById('submitBtn');
    const errorContainer = document.getElementById('error-container');
    const errorText = document.getElementById('error-text');
    
    submitBtn.disabled = true;
    btnText.classList.add('hidden');
    btnIcon.classList.add('hidden');
    btnSpinner.classList.remove('hidden');
    errorContainer.classList.add('hidden');

    try {
        const res = await fetch('/api/users/login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, password })
        });
        const data = await res.json();
        
        if (res.ok) {
            localStorage.setItem('token', data.token);
            localStorage.setItem('user', JSON.stringify({
                id: data._id,
                name: data.name,
                email: data.email,
                role: data.role
            }));
            window.location.href = '/';
        } else {
            errorText.textContent = data.message || 'Login failed';
            errorContainer.classList.remove('hidden');
        }
    } catch (err) {
        errorText.textContent = 'Network error occurred';
        errorContainer.classList.remove('hidden');
    }

    // Reset UI
    submitBtn.disabled = false;
    btnText.classList.remove('hidden');
    btnIcon.classList.remove('hidden');
    btnSpinner.classList.add('hidden');
}
</script>
