<div class="space-y-8 max-w-[1400px] mx-auto">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 bg-white dark:bg-[#001E2B] p-8 rounded-2xl border border-[#E8EDEB] dark:border-[#1C2D38]">
        <div>
            <div class="flex items-center gap-2 mb-1">
                <span class="w-2 h-2 bg-[#00ED64] rounded-full animate-pulse"></span>
                <span class="text-[10px] font-black text-[#00ED64] uppercase tracking-[0.2em]">System Online</span>
            </div>
            <h1 class="text-3xl font-black dark:text-white mb-1 tracking-tight">Case Clusters</h1>
            <p class="text-slate-500 dark:text-[#889397] font-medium text-sm">Real-time legal database management and monitoring</p>
        </div>
        
        <button 
            id="addCaseBtn"
            onclick="openAddModal()"
            class="hidden flex items-center gap-2 bg-[#00ED64] text-[#001E2B] px-6 py-3 rounded-lg font-black text-xs uppercase tracking-widest shadow-lg shadow-[#00ED64]/20 hover:bg-[#00D158] transition-all"
        >
            <i data-lucide="plus" width="16" height="16" stroke-width="3"></i>
            Create New Case
        </button>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="bg-white dark:bg-[#001E2B] p-6 rounded-xl border border-[#E8EDEB] dark:border-[#1C2D38] hover:border-[#00ED64] transition-colors group">
            <div class="flex justify-between items-start">
                <div>
                    <span class="text-[10px] font-black text-slate-500 dark:text-[#889397] uppercase tracking-widest">Total Documents</span>
                    <h3 id="statTotal" class="text-3xl font-black dark:text-white mt-1">-</h3>
                </div>
                <div class="p-3 rounded-lg bg-slate-50 dark:bg-[#023448] text-slate-400 group-hover:text-[#00ED64] transition-colors">
                    <i data-lucide="database" width="20" height="20"></i>
                </div>
            </div>
        </div>
        <div class="bg-white dark:bg-[#001E2B] p-6 rounded-xl border border-[#E8EDEB] dark:border-[#1C2D38] hover:border-amber-500 transition-colors group">
            <div class="flex justify-between items-start">
                <div>
                    <span class="text-[10px] font-black text-slate-500 dark:text-[#889397] uppercase tracking-widest">Pending Sync</span>
                    <h3 id="statPending" class="text-3xl font-black dark:text-white mt-1">-</h3>
                </div>
                <div class="p-3 rounded-lg bg-slate-50 dark:bg-[#023448] text-slate-400 group-hover:text-amber-500 transition-colors">
                    <i data-lucide="refresh-cw" width="20" height="20"></i>
                </div>
            </div>
        </div>
        <div class="bg-white dark:bg-[#001E2B] p-6 rounded-xl border border-[#E8EDEB] dark:border-[#1C2D38] hover:border-[#1a73e8] transition-colors group">
            <div class="flex justify-between items-start">
                <div>
                    <span class="text-[10px] font-black text-slate-500 dark:text-[#889397] uppercase tracking-widest">Active Operations</span>
                    <h3 id="statActive" class="text-3xl font-black dark:text-white mt-1">-</h3>
                </div>
                <div class="p-3 rounded-lg bg-slate-50 dark:bg-[#023448] text-slate-400 group-hover:text-[#1a73e8] transition-colors">
                    <i data-lucide="activity" width="20" height="20"></i>
                </div>
            </div>
        </div>
        <div class="bg-white dark:bg-[#001E2B] p-6 rounded-xl border border-[#E8EDEB] dark:border-[#1C2D38] hover:border-[#00ED64] transition-colors group">
            <div class="flex justify-between items-start">
                <div>
                    <span class="text-[10px] font-black text-slate-500 dark:text-[#889397] uppercase tracking-widest">Resolved</span>
                    <h3 id="statClosed" class="text-3xl font-black dark:text-white mt-1">-</h3>
                </div>
                <div class="p-3 rounded-lg bg-slate-50 dark:bg-[#023448] text-slate-400 group-hover:text-[#00ED64] transition-colors">
                    <i data-lucide="check-circle-2" width="20" height="20"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="bg-white dark:bg-[#001E2B] rounded-2xl border border-[#E8EDEB] dark:border-[#1C2D38] overflow-hidden shadow-sm">
        <div class="p-6 border-b border-[#E8EDEB] dark:border-[#1C2D38] bg-slate-50/50 dark:bg-[#023448]/20 flex flex-col md:flex-row md:items-center justify-between gap-6">
            <div class="flex items-center gap-3">
                <i data-lucide="layers" class="text-[#00ED64]" width="20" height="20"></i>
                <h2 class="text-lg font-black dark:text-white uppercase tracking-wider">Document Collections</h2>
            </div>
            <div class="flex items-center gap-3">
                <div class="relative">
                    <div class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">
                        <i data-lucide="search" width="14" height="14"></i>
                    </div>
                    <input 
                        type="text" 
                        id="searchInput"
                        placeholder="Filter by case # or title..."
                        class="pl-10 pr-4 py-2 text-sm rounded-lg bg-white dark:bg-[#001E2B] border border-[#E8EDEB] dark:border-[#1C2D38] outline-none focus:border-[#00ED64] w-full md:w-64 transition-all dark:text-white"
                        onkeyup="filterCases()"
                    />
                </div>
                <button class="p-2.5 bg-white dark:bg-[#001E2B] text-slate-500 border border-[#E8EDEB] dark:border-[#1C2D38] rounded-lg hover:border-[#00ED64] transition-colors">
                    <i data-lucide="filter" width="16" height="16"></i>
                </button>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50/50 dark:bg-[#023448]/30 border-b border-[#E8EDEB] dark:border-[#1C2D38]">
                        <th class="px-6 py-4 text-[10px] font-black text-slate-500 dark:text-[#889397] uppercase tracking-widest">Case ID</th>
                        <th class="px-6 py-4 text-[10px] font-black text-slate-500 dark:text-[#889397] uppercase tracking-widest">Title / Schema</th>
                        <th class="px-6 py-4 text-[10px] font-black text-slate-500 dark:text-[#889397] uppercase tracking-widest">State</th>
                        <th class="px-6 py-4 text-[10px] font-black text-slate-500 dark:text-[#889397] uppercase tracking-widest">Principals</th>
                        <th class="px-6 py-4 text-right text-[10px] font-black text-slate-500 dark:text-[#889397] uppercase tracking-widest">Actions</th>
                    </tr>
                </thead>
                <tbody id="casesTableBody" class="divide-y divide-[#E8EDEB] dark:divide-[#1C2D38]">
                    <!-- Populated via JS -->
                </tbody>
            </table>
            <div id="noCasesMsg" class="hidden p-20 text-center">
                <i data-lucide="search-x" class="mx-auto text-slate-300 mb-4" width="48" height="48"></i>
                <p class="text-slate-400 font-bold">No documents match the current filter criteria.</p>
            </div>
        </div>
    </div>

    <!-- Add Case Modal -->
    <div id="addModal" class="hidden fixed inset-0 z-[100] flex items-center justify-center p-4">
        <div class="absolute inset-0 bg-[#001E2B]/80 backdrop-blur-sm animate-fade-in" onclick="closeAddModal()"></div>
        <div class="relative w-full max-w-2xl bg-white dark:bg-[#001E2B] rounded-2xl border border-[#1C2D38] shadow-2xl overflow-hidden animate-slide-up">
            <div class="p-8">
                <div class="flex items-center gap-3 mb-8">
                    <div class="p-2 bg-[#00ED64]/10 rounded-lg">
                        <i data-lucide="plus-square" class="text-[#00ED64]" width="24" height="24"></i>
                    </div>
                    <div>
                        <h2 class="text-2xl font-black dark:text-white tracking-tight">Insert Document</h2>
                        <p class="text-xs text-[#889397] font-bold uppercase tracking-widest">New Case Registry</p>
                    </div>
                </div>

                <form onsubmit="handleAddCase(event)" class="space-y-6">
                    <div class="grid grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label class="text-[10px] font-black uppercase text-[#889397] tracking-widest ml-1">Case Number</label>
                            <input type="text" id="caseNumber" required
                            class="w-full px-4 py-3 rounded-lg bg-slate-50 dark:bg-[#023448]/30 border border-[#E8EDEB] dark:border-[#1C2D38] focus:border-[#00ED64] outline-none transition-all dark:text-white font-medium"
                            placeholder="CASE-2024-XXX" />
                        </div>
                        <div class="space-y-2">
                            <label class="text-[10px] font-black uppercase text-[#889397] tracking-widest ml-1">Case Title</label>
                            <input type="text" id="caseTitle" required
                            class="w-full px-4 py-3 rounded-lg bg-slate-50 dark:bg-[#023448]/30 border border-[#E8EDEB] dark:border-[#1C2D38] focus:border-[#00ED64] outline-none transition-all dark:text-white font-medium"
                            placeholder="Brief Title..." />
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label class="text-[10px] font-black uppercase text-[#889397] tracking-widest ml-1">Petitioner</label>
                            <input type="text" id="petitioner" required
                            class="w-full px-4 py-3 rounded-lg bg-slate-50 dark:bg-[#023448]/30 border border-[#E8EDEB] dark:border-[#1C2D38] focus:border-[#00ED64] outline-none transition-all dark:text-white font-medium" />
                        </div>
                        <div class="space-y-2">
                            <label class="text-[10px] font-black uppercase text-[#889397] tracking-widest ml-1">Respondent</label>
                            <input type="text" id="respondent" required
                            class="w-full px-4 py-3 rounded-lg bg-slate-50 dark:bg-[#023448]/30 border border-[#E8EDEB] dark:border-[#1C2D38] focus:border-[#00ED64] outline-none transition-all dark:text-white font-medium" />
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label class="text-[10px] font-black uppercase text-[#889397] tracking-widest ml-1">Court</label>
                            <input type="text" id="courtName" required
                            class="w-full px-4 py-3 rounded-lg bg-slate-50 dark:bg-[#023448]/30 border border-[#E8EDEB] dark:border-[#1C2D38] focus:border-[#00ED64] outline-none transition-all dark:text-white font-medium" />
                        </div>
                        <div class="space-y-2">
                            <label class="text-[10px] font-black uppercase text-[#889397] tracking-widest ml-1">Hearing Date</label>
                            <input type="date" id="hearingDate"
                            class="w-full px-4 py-3 rounded-lg bg-slate-50 dark:bg-[#023448]/30 border border-[#E8EDEB] dark:border-[#1C2D38] focus:border-[#00ED64] outline-none transition-all dark:text-white font-medium" />
                        </div>
                    </div>

                    <div class="space-y-2">
                        <label class="text-[10px] font-black uppercase text-[#889397] tracking-widest ml-1">Case Description</label>
                        <textarea id="description" required rows="3"
                            class="w-full px-4 py-3 rounded-lg bg-slate-50 dark:bg-[#023448]/30 border border-[#E8EDEB] dark:border-[#1C2D38] focus:border-[#00ED64] outline-none transition-all dark:text-white font-medium resize-none"></textarea>
                    </div>

                    <div class="flex gap-4 pt-4">
                        <button type="button" onclick="closeAddModal()"
                            class="flex-1 py-3 text-slate-500 font-bold hover:bg-slate-50 dark:hover:bg-[#023448] rounded-lg transition-all">
                            Discard
                        </button>
                        <button type="submit"
                            class="flex-[2] py-3 bg-[#00ED64] text-[#001E2B] rounded-lg font-black text-xs uppercase tracking-widest hover:bg-[#00D158] transition-all shadow-lg shadow-[#00ED64]/20">
                            Insert Document
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>


<style>
@keyframes slideUp {
    from { opacity: 0; transform: scale(0.9) translateY(20px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
}
.animate-slide-up {
    animation: slideUp 0.3s ease-out forwards;
}
@keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
}
.animate-fade-in {
    animation: fadeIn 0.3s ease-out forwards;
}
</style>

<script src="/js/dashboard.js"></script>
